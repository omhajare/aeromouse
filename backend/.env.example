# ===== Flask Server =====
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ===== CORS =====
# Comma-separated allowed origins
# Dev: http://localhost:3000
# Prod: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# ===== PostgreSQL Database =====
# Format: postgresql://user:password@host:port/dbname
# Dev: postgresql://postgres:yourpassword@localhost:5432/aeromouse
# Prod (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/aeromouse?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/aeromouse

